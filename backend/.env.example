SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Import provider: thesportsdb | api-football
IMPORT_PROVIDER=thesportsdb
IMPORT_SEASON=2026

# API-Football (recommended for full fixture coverage)
API_FOOTBALL_KEY=your-rapidapi-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1032
API_FOOTBALL_USE_RAPIDAPI=false
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com

# TheSportsDB (public/free)
THESPORTSDB_FREE_KEY=123
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json/3
THESPORTSDB_LEAGUE_ID=4406
THESPORTSDB_MAX_ROUNDS=20
THESPORTSDB_EMPTY_ROUNDS_STOP=3
THESPORTSDB_REQUEST_DELAY_MS=350
THESPORTSDB_MAX_RETRIES=3
THESPORTSDB_RETRY_BASE_MS=1500
THESPORTSDB_SECOND_STAGE_MONTH=7
ROUND_OPEN_LOOKAHEAD_HOURS=120
ROUND_FORCE_FINISHED_AFTER_HOURS=72

# Optional runtime tuning
SYNC_LOOKBACK_HOURS=48
SYNC_LOOKAHEAD_HOURS=6
THESPORTSDB_SYNC_DELAY_MS=500
